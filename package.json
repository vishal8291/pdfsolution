{
  "name": "pdfsolution",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev":        "vite",
    "dev:server": "tsx server/index.ts",
    "build":      "tsc && vite build",
    "preview":    "vite preview",
    "start":      "NODE_ENV=production node --import tsx/esm server/index.ts",
    "pm2:start":  "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload pdf-server --update-env",
    "pm2:stop":   "pm2 stop pdf-server",
    "pm2:logs":   "pm2 logs pdf-server",
    "pm2:monit":  "pm2 monit",
    "audit":      "npm audit --audit-level=high",
    "update:deps":"npm update && npm audit fix"
  },
  "dependencies": {
    "@types/react-router-dom": "^5.3.3",
    "docx": "^9.6.1",
    "dotenv": "^17.4.1",
    "google-auth-library": "^10.6.2",
    "jszip": "^3.10.1",
    "mongodb": "^7.1.1",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "razorpay": "^2.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
